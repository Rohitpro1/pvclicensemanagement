# ===== MongoDB Atlas =====
# Get this from MongoDB Atlas > Connect > Drivers
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=pvc_license_manager

# ===== Security =====
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# ===== Seed admin (created on first boot) =====
ADMIN_EMAIL=admin@pvccards.com
ADMIN_PASSWORD=Admin@123

# ===== CORS (comma separated; * allows all) =====
CORS_ORIGINS=*
